# Database (use full URL or individual components)
EPISODIQ_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/episodiq
# EPISODIQ_DB_HOST=localhost
# EPISODIQ_DB_PORT=5432
# EPISODIQ_DB_NAME=episodiq
# EPISODIQ_DB_USER=episodiq
# EPISODIQ_DB_PASSWORD=

# Embedder service
EPISODIQ_EMBEDDER_URL=           # base URL of embedding service
EPISODIQ_EMBEDDER_MODEL=         # model name passed to the embedder
EPISODIQ_EMBEDDER_API_KEY=       # API key for remote embedder
EPISODIQ_EMBEDDER_CHUNK_SIZE=8191  # max characters per embedding chunk
EPISODIQ_MESSAGE_DIMS=1024         # embedding dimensions stored in DB

# Proxy timeouts (seconds)
EPISODIQ_PROCESS_INPUT_TIMEOUT=15    # pre-forward pipeline timeout
EPISODIQ_POSTPROCESS_TIMEOUT=120     # post-forward pipeline timeout

# Analytics — similarity search
EPISODIQ_PREFETCH_N=250    # HNSW candidates to prefetch
EPISODIQ_TOP_K=25          # top-k after sparse cosine rerank

# Signal thresholds (tune with: episodiq tune signal-thresholds / path-freq / prefetch-topk)
EPISODIQ_FAIL_RISK_ACTION_THRESHOLD=0.06
EPISODIQ_SUCCESS_SIGNAL_ACTION_THRESHOLD=0.06
EPISODIQ_LOOP_THRESHOLD=2      # consecutive repeated transitions to flag loop
EPISODIQ_LOW_ENTROPY=0.5       # below → confident consensus (anomaly check)
EPISODIQ_HIGH_ENTROPY=2.5      # above → agent is exploring

# Dead-end prediction
EPISODIQ_DEAD_END_MODEL=       # path to trained .joblib model
EPISODIQ_DEAD_END_THRESHOLD=0.5  # probability threshold for flagging

# Clustering
EPISODIQ_DECAY_LAMBDA=0.8        # exponential decay for transition profiles
EPISODIQ_MERGE_THRESHOLD=0.9     # cosine threshold for merging near-duplicate annotations
EPISODIQ_API_CONCURRENCY=8       # parallel LLM calls during annotation

# Logging
EPISODIQ_LOG_LEVEL=info          # debug / info / warning / error
EPISODIQ_LOG_FORMAT=json         # json or console
EPISODIQ_LOG_FILE=               # optional log file path
